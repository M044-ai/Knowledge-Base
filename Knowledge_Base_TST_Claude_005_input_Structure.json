  "blocks": [
    {
      "id": "blk_arch_001",
      "concept": "architecture_web",
      "type": "definition",
      "text": "Une application web moderne s’appuie sur plusieurs couches qui interagissent entre elles pour fournir un service à l’utilisateur."
    },
    {
      "id": "blk_arch_002",
      "concept": "architecture_web",
      "type": "definition",
      "text": "Le frontend correspond à l’interface utilisée par l’utilisateur, tandis que l’API backend gère la logique et le dialogue avec la base de données."
    },
    {
      "id": "blk_arch_003",
      "concept": "architecture_web",
      "type": "definition",
      "text": "PostgreSQL est utilisé pour stocker les données, et l’infrastructure AWS permet de faire tourner l’ensemble."
    },
    {
      "id": "blk_arch_004",
      "concept": "architecture_web",
      "type": "explanation",
      "text": "La chaîne complète peut se lire ainsi : le navigateur communique avec l’API, l’API lit ou écrit dans PostgreSQL, et l’ensemble est hébergé sur AWS."
    },

    {
      "id": "blk_api_001",
      "concept": "api_rest",
      "type": "definition",
      "text": "Une API REST est une interface qui permet à des applications de communiquer via des requêtes HTTP."
    },
    {
      "id": "blk_api_002",
      "concept": "api_rest",
      "type": "definition",
      "text": "Elle expose des endpoints qui permettent de lire ou de modifier des données."
    },
    {
      "id": "blk_api_003",
      "concept": "api_rest",
      "type": "example",
      "text": "Des exemples d’endpoints sont GET /users et POST /orders."
    },
    {
      "id": "blk_api_004",
      "concept": "api_rest",
      "type": "explanation",
      "text": "Dans ce contexte, JSON fait partie des notions à comprendre pour suivre les échanges de données."
    },

    {
      "id": "blk_ts_001",
      "concept": "typescript",
      "type": "definition",
      "text": "TypeScript est une extension de JavaScript qui ajoute un système de typage."
    },
    {
      "id": "blk_ts_002",
      "concept": "typescript",
      "type": "explanation",
      "text": "La différence entre JavaScript et TypeScript tient donc à l’ajout de types dans TypeScript."
    },
    {
      "id": "blk_ts_003",
      "concept": "typescript",
      "type": "explanation",
      "text": "Le typage, avec des types et des interfaces, permet de détecter certaines erreurs avant l’exécution et de rendre le code plus robuste."
    },

    {
      "id": "blk_pg_001",
      "concept": "postgresql",
      "type": "definition",
      "text": "PostgreSQL est une base de données relationnelle utilisée pour stocker des données structurées et effectuer des requêtes SQL."
    },
    {
      "id": "blk_pg_002",
      "concept": "postgresql",
      "type": "explanation",
      "text": "Les questions associées portent notamment sur la table, la clé primaire, l’index, SQL et l’intérêt d’utiliser PostgreSQL."
    },
    {
      "id": "blk_pg_003",
      "concept": "postgresql",
      "type": "warning",
      "text": "Une erreur fréquente consiste à confondre l’API et la base de données, alors qu’elles n’ont pas le même rôle."
    },
    {
      "id": "blk_pg_004",
      "concept": "postgresql",
      "type": "explanation",
      "text": "Une autre question liée consiste à distinguer le stockage d’une base de données structurée."
    }
  ],
