  "blocks": [
    { "id": "blk_arch_001", "concept": "architecture_web", "type": "definition", "text": "Une application web moderne s'appuie sur plusieurs couches qui interagissent entre elles pour fournir un service à l'utilisateur." },
    { "id": "blk_arch_002", "concept": "architecture_web", "type": "definition", "text": "Le frontend correspond à l'interface utilisée par l'utilisateur, tandis que l'API backend gère la logique et le dialogue avec la base de données." },
    { "id": "blk_arch_003", "concept": "architecture_web", "type": "definition", "text": "PostgreSQL est utilisé pour stocker les données, et l'infrastructure AWS permet de faire tourner l'ensemble." },
    { "id": "blk_arch_004", "concept": "architecture_web", "type": "explanation", "text": "La chaîne complète peut se lire ainsi : le navigateur communique avec l'API, l'API lit ou écrit dans PostgreSQL, et l'ensemble est hébergé sur AWS." },

    { "id": "blk_js_001", "concept": "javascript", "type": "definition", "text": "JavaScript est le langage de base du développement web." },
    { "id": "blk_js_002", "concept": "javascript", "type": "explanation", "text": "Comprendre JavaScript permet ensuite de comprendre TypeScript, qui s'appuie sur lui." },
    { "id": "blk_js_003", "concept": "javascript", "type": "definition", "text": "Les notions à rencontrer dans cette base sont les variables, les fonctions, les objets, async / await et les modules." },

    { "id": "blk_ts_001", "concept": "typescript", "type": "definition", "text": "TypeScript est une extension de JavaScript qui ajoute un système de typage." },
    { "id": "blk_ts_002", "concept": "typescript", "type": "explanation", "text": "Le typage permet de détecter certaines erreurs avant l'exécution et de rendre le code plus robuste." },
    { "id": "blk_ts_003", "concept": "typescript", "type": "definition", "text": "Le code TypeScript est ensuite compilé en JavaScript avant d'être exécuté." },

    { "id": "blk_backend_001", "concept": "backend", "type": "definition", "text": "Le backend est la partie serveur d'une application qui traite les requêtes et applique la logique métier." },
    { "id": "blk_backend_002", "concept": "backend", "type": "explanation", "text": "Il gère les API et l'accès aux bases de données." },
    { "id": "blk_backend_003", "concept": "backend", "type": "explanation", "text": "Dans la chaîne décrite ici, le client dialogue avec l'API, puis l'API dialogue avec la base de données." },

    { "id": "blk_api_001", "concept": "api_rest", "type": "definition", "text": "Une API REST est une interface qui permet à des applications de communiquer via des requêtes HTTP." },
    { "id": "blk_api_002", "concept": "api_rest", "type": "definition", "text": "Elle expose des endpoints qui permettent de lire ou de modifier des données." },
    { "id": "blk_api_003", "concept": "api_rest", "type": "example", "text": "Des exemples d'endpoints sont GET /users et POST /orders." },
    { "id": "blk_api_004", "concept": "api_rest", "type": "explanation", "text": "Dans ce contexte, JSON fait partie des notions à comprendre pour suivre les échanges de données." },

    { "id": "blk_json_001", "concept": "json", "type": "definition", "text": "JSON est un format de données simple utilisé pour échanger des informations entre un client et un serveur." },
    { "id": "blk_json_002", "concept": "json", "type": "explanation", "text": "Dans le cadre d'une API REST, les données transitent souvent au format JSON." },

    { "id": "blk_pg_001", "concept": "postgresql", "type": "definition", "text": "PostgreSQL est une base de données relationnelle utilisée pour stocker des données structurées et effectuer des requêtes SQL." },
    { "id": "blk_pg_002", "concept": "postgresql", "type": "definition", "text": "Les notions associées dans cette base sont la table, la relation et la requête SQL." },
    { "id": "blk_pg_003", "concept": "postgresql", "type": "example", "text": "Un exemple de requête SQL est SELECT * FROM users;" },

    { "id": "blk_cloud_001", "concept": "cloud", "type": "definition", "text": "Le cloud permet d'héberger des applications et des bases de données sans gérer directement l'infrastructure physique." },
    { "id": "blk_cloud_002", "concept": "cloud", "type": "explanation", "text": "Dans cette stack, le cloud correspond à la couche qui fait tourner l'ensemble de l'application." },

    { "id": "blk_aws_001", "concept": "aws", "type": "definition", "text": "AWS est une plateforme cloud qui permet d'héberger des applications, des bases de données et des services." },
    { "id": "blk_aws_002", "concept": "aws", "type": "explanation", "text": "Parmi les services cités dans cette base figurent EC2 pour les serveurs, S3 pour le stockage, RDS pour une base PostgreSQL et Lambda pour des fonctions serverless." },
    { "id": "blk_aws_003", "concept": "aws", "type": "explanation", "text": "Dans cette stack, AWS représente l'infrastructure d'hébergement." },

    { "id": "blk_explore_arch_001", "concept": "architecture_web", "type": "definition", "text": "Explorer l'architecture web revient à relier l'interface utilisateur, le backend, la base de données et l'infrastructure cloud." },
    { "id": "blk_explore_arch_002", "concept": "architecture_web", "type": "explanation", "text": "La compréhension de la chaîne complète aide à situer chaque notion dans le fonctionnement global de l'application." },

    { "id": "blk_explore_js_001", "concept": "javascript", "type": "explanation", "text": "Dans ce mode, JavaScript est abordé à travers la différence avec TypeScript et à travers des notions comme async / await et les modules." },
    { "id": "blk_explore_js_002", "concept": "javascript", "type": "definition", "text": "L'objectif reste de comprendre les bases de langage qui servent ensuite à lire du code moderne." },

    { "id": "blk_explore_ts_001", "concept": "typescript", "type": "definition", "text": "TypeScript se distingue de JavaScript par l'ajout d'un système de typage." },
    { "id": "blk_explore_ts_002", "concept": "typescript", "type": "explanation", "text": "Dans ce mode, la notion centrale est le typage, avec les types et les interfaces." },

    { "id": "blk_explore_backend_001", "concept": "backend", "type": "definition", "text": "Explorer le backend consiste à comprendre son rôle dans le traitement des requêtes et l'accès aux données." },
    { "id": "blk_explore_backend_002", "concept": "backend", "type": "explanation", "text": "Le backend se situe entre le client et la base de données dans la logique de fonctionnement de l'application." },

    { "id": "blk_explore_api_001", "concept": "api_rest", "type": "definition", "text": "Dans ce mode, l'API REST est abordée à travers sa définition et la notion d'endpoint." },
    { "id": "blk_explore_api_002", "concept": "api_rest", "type": "explanation", "text": "Ces notions servent à comprendre comment des actions sont exposées et appelées dans une application." },

    { "id": "blk_explore_json_001", "concept": "json", "type": "definition", "text": "JSON est la notion à retenir pour le format d'échange de données dans cette stack." },

    { "id": "blk_explore_pg_001", "concept": "postgresql", "type": "definition", "text": "Dans ce mode, PostgreSQL est abordé à travers trois notions : la table, la relation et la requête SQL." },
    { "id": "blk_explore_pg_002", "concept": "postgresql", "type": "explanation", "text": "Ces notions permettent de comprendre comment les données sont organisées et interrogées." },

    { "id": "blk_explore_cloud_001", "concept": "cloud", "type": "definition", "text": "Le cloud est ici abordé par son rôle d'hébergement et par la raison pour laquelle il est utilisé." },

    { "id": "blk_explore_aws_001", "concept": "aws", "type": "definition", "text": "AWS est ici abordé par son rôle dans une application et par les services qu'il met à disposition." },

    { "id": "blk_sl_arch_001", "concept": "architecture_web", "type": "definition", "text": "Dans le mode Se lancer, l'architecture web sert de vue globale pour relier déploiement, responsabilités techniques et erreurs fréquentes." },
    { "id": "blk_sl_arch_002", "concept": "architecture_web", "type": "warning", "text": "Plusieurs erreurs classiques portent sur la confusion entre les grandes briques du système ou sur une mauvaise lecture de la structure du projet." },

    { "id": "blk_sl_js_001", "concept": "javascript", "type": "definition", "text": "Les questions JavaScript portent sur la différence avec TypeScript, sur async / await et sur la différence entre let, const et var." },
    { "id": "blk_sl_js_002", "concept": "javascript", "type": "warning", "text": "Une erreur associée consiste à croire que TypeScript remplace JavaScript." },

    { "id": "blk_sl_ts_001", "concept": "typescript", "type": "definition", "text": "Les questions TypeScript portent sur sa différence avec JavaScript, sur l'intérêt du typage et sur la notion de type ou d'interface." },
    { "id": "blk_sl_ts_002", "concept": "typescript", "type": "warning", "text": "Une erreur associée consiste à ne pas voir TypeScript comme une extension de JavaScript." },

    { "id": "blk_sl_backend_001", "concept": "backend", "type": "definition", "text": "Les questions backend portent sur son rôle dans l'application et sur la notion de serveur." },
    { "id": "blk_sl_backend_002", "concept": "backend", "type": "warning", "text": "Une erreur associée consiste à mélanger frontend et backend." },

    { "id": "blk_sl_api_001", "concept": "api_rest", "type": "definition", "text": "Les questions API REST portent sur sa définition, sur les endpoints, sur la différence entre GET et POST, et sur le rôle de JSON dans les échanges." },
    { "id": "blk_sl_api_002", "concept": "api_rest", "type": "warning", "text": "Les erreurs fréquentes portent sur la confusion entre API et base de données ou sur une mauvaise compréhension de HTTP." },

    { "id": "blk_sl_json_001", "concept": "json", "type": "definition", "text": "Dans ce mode, JSON apparaît surtout à travers son rôle dans une API et dans l'échange d'informations entre client et serveur." },

    { "id": "blk_sl_pg_001", "concept": "postgresql", "type": "definition", "text": "Les questions PostgreSQL portent sur la table, la clé primaire, l'index, SQL, l'intérêt d'utiliser PostgreSQL et la différence entre stockage et base de données." },
    { "id": "blk_sl_pg_002", "concept": "postgresql", "type": "warning", "text": "Une erreur fréquente consiste à confondre l'API avec la base de données, alors qu'elles n'ont pas le même rôle." },

    { "id": "blk_sl_cloud_001", "concept": "cloud", "type": "definition", "text": "Les questions cloud portent sur la raison d'utiliser le cloud, sur la notion de serveur et sur le déploiement." },
    { "id": "blk_sl_cloud_002", "concept": "cloud", "type": "explanation", "text": "Le cloud sert ici de cadre pour situer l'hébergement et l'infrastructure de l'application." },

    { "id": "blk_sl_aws_001", "concept": "aws", "type": "definition", "text": "Les questions AWS portent sur son rôle comme plateforme cloud et sur sa place dans le déploiement d'une application." }
  ],
